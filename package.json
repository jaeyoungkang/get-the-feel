{
  "name": "get-the-feel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "pages:build": "NEXT_PUBLIC_BASE_PATH=/get-the-feel next build",
    "pages:check": "npm run pages:build && node scripts/deploy/check-pages-export.mjs --base-path /get-the-feel",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src scripts --max-warnings=0",
    "content:check": "node scripts/content/check.mjs",
    "content:sync-legacy": "node scripts/content/sync-legacy-data.mjs",
    "legacy:check": "node --check public/legacy/c4-3/app.js && node --check public/legacy/c4-3/data.js && node scripts/legacy/check-baseline.mjs",
    "ui:check": "node scripts/ui/check-explain-contract.mjs && node scripts/design/check-baseline.mjs",
    "skills:sync": "python3 scripts/sync-agent-skills.py",
    "guard:skills": "python3 scripts/sync-agent-skills.py --check",
    "contract-maps:check": "node scripts/contract-maps/check.mjs",
    "mc:validate-story-chain": "node scripts/mission-control/mc-validate-story-chain.mjs",
    "mc:audit-surface": "node scripts/mission-control/mc-audit-surface.mjs",
    "mc:audit-story-surface": "npm run mc:audit-surface",
    "mc:check-new-criticals": "node scripts/mission-control/mc-check-new-criticals.mjs",
    "mc:status": "node scripts/mission-control/mc-status.mjs",
    "mc:add-promise": "node scripts/mission-control/mc-add-promise.mjs",
    "mc:propagate": "node scripts/mission-control/mc-propagate.mjs",
    "pk:start": "node scripts/project-knowledge.mjs start",
    "pk:remember": "node scripts/project-knowledge.mjs remember",
    "pk:log": "node scripts/project-knowledge.mjs log",
    "pk:validate": "node scripts/project-knowledge.mjs validate",
    "project:event": "node scripts/project-knowledge.mjs event",
    "quality:audit": "npm run guard:skills && npm run pk:validate && npm run contract-maps:check",
    "quality:contracts": "npm run quality:audit && npm run mc:validate-story-chain && npm run mc:audit-surface && npm run mc:check-new-criticals",
    "quality:base": "npm run quality:contracts",
    "quality:check": "npm run content:check && npm run legacy:check && npm run ui:check && npm run typecheck && npm run lint && npm run build && npm run pages:check && npm run quality:contracts",
    "quality:release": "npm run quality:check"
  },
  "dependencies": {
    "mdast-util-to-string": "^4.0.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2"
  }
}
