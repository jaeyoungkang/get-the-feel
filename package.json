{
  "name": "get-the-feel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src scripts --max-warnings=0",
    "prototype:sync": "node scripts/prototype/sync-current.mjs",
    "verdict": "node tools/verdict/check.mjs c4-3",
    "quality:check": "npm run prototype:sync && npm run verdict && npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2"
  }
}
